# Server Configuration
PORT=8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# Redis (required)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# TTS Provider: "replicate", "vastai", "local", or "mock"
# Replicate with Minimax is recommended for easy setup
TTS_PROVIDER=replicate

# Replicate API (recommended - easiest setup)
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# Vast.ai F5-TTS (~$0.15-0.50 per 10hr audiobook) - RECOMMENDED
# See vastai-scripts/README.md for setup instructions
# 1. Rent a GPU on vast.ai
# 2. Run: pip install f5-tts fastapi uvicorn httpx
# 3. Start the API server (see README)
# 4. Set the URL below
VASTAI_URL=http://your-vastai-ip:8080
VASTAI_API_KEY=

# Reference text for voice cloning (transcription of your reference audio clip)
# Leave empty to use automatic speech recognition
TTS_REF_TEXT=

# YouTube Data API (required for video search)
# Get your key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Clerk Authentication (optional for dev, required for prod)
# Get your keys at: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Paddle Payments (optional for dev, required for prod)
# Get your keys at: https://vendors.paddle.com
PADDLE_API_KEY=your_paddle_api_key_here
PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=pdl_your_webhook_secret_here
PADDLE_ONE_TIME_PRICE_ID=pri_your_price_id_here
PADDLE_SUBSCRIPTION_PRICE_ID=pri_your_subscription_price_id_here

# Bunny.net CDN (required for file storage)
# Get your keys at: https://bunny.net
BUNNY_STORAGE_ZONE=your_storage_zone
BUNNY_API_KEY=your_bunny_api_key_here
BUNNY_CDN_URL=https://your-zone.b-cdn.net

# Temp directory for processing
TEMP_DIR=/tmp/echomancer
