# ============================================
# ECHOMANCER CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-string-in-production

# ============================================
# REQUIRED FOR BASIC FUNCTIONALITY
# ============================================

# TTS Provider: "replicate" or "vastai"
# - replicate: Easy setup, ~$1.50/book (includes $3 voice clone)
# - vastai: Cheapest, ~$0.15/book (requires GPU rental)
TTS_PROVIDER=replicate

# Replicate API (if using TTS_PROVIDER=replicate)
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_token_here

# Vast.ai (if using TTS_PROVIDER=vastai) - CHEAPEST OPTION
# See vastai-scripts/README.md for setup
VASTAI_URL=
VASTAI_API_KEY=

# ============================================
# REQUIRED FOR PRODUCTION
# ============================================

# Supabase Database
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_KEY=eyJ...your_service_key

# Stripe Payments
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_ONE_TIME=price_xxxxx
STRIPE_PRICE_ID_SUBSCRIPTION=price_xxxxx

# ============================================
# OPTIONAL
# ============================================

# YouTube Data API (for voice search feature)
# Get your key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Redis (for background job queue - optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Bunny.net CDN (for storing audiobooks permanently)
# Get your keys at: https://bunny.net
BUNNY_STORAGE_ZONE=
BUNNY_API_KEY=
BUNNY_CDN_URL=

# Temp directory for processing
TEMP_DIR=/tmp/echomancer
